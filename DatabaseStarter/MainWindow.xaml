<Window x:Class="DatabaseStarter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="clr-namespace:DatabaseStarter.Converters"
        xmlns:vm="clr-namespace:DatabaseStarter.ViewModels"
        mc:Ignorable="d"
        Title="Database Starter – Portable DB Manager"
        Height="700" Width="900"
        MinHeight="500" MinWidth="700"
        WindowStartupLocation="CenterScreen"
        Background="#FF1E1E2E">

    <Window.Resources>
        <converters:StatusToBrushConverter x:Key="StatusToBrushConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>

        <!-- Compact Button Style -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="MinWidth" Value="90"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="3,0"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InstallButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#FF4CAF50"/>
        </Style>
        <Style x:Key="StartButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#FF2196F3"/>
        </Style>
        <Style x:Key="StopButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#FFFF9800"/>
        </Style>
        <Style x:Key="UninstallButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#FFF44336"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#FF181825" Padding="24,16">
            <StackPanel>
                <TextBlock Text="🗄️ Database Starter"
                           FontSize="24" FontWeight="Bold"
                           Foreground="#FFCDD6F4"/>
                <TextBlock Text="Portable MySQL, MariaDB &amp; PostgreSQL Instanzen verwalten"
                           FontSize="13" Foreground="#FFA6ADC8" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Database Cards -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16">
            <ItemsControl ItemsSource="{Binding Databases}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:DatabaseViewModel}">
                        <Border Background="#FF313244" CornerRadius="10" Margin="4,3"
                                Padding="14,8" BorderBrush="#FF45475A" BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Row 0: Engine icon/name + version selector + status -->
                                <DockPanel Grid.Row="0" Margin="0,0,0,4">
                                    <Ellipse DockPanel.Dock="Left" Width="10" Height="10"
                                             Fill="{Binding Status, Converter={StaticResource StatusToBrushConverter}}"
                                             Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" Margin="0,0,12,0">
                                        <Run Text="{Binding EngineIcon, Mode=OneWay}" FontSize="16"/>
                                        <Run Text=" "/>
                                        <Run Text="{Binding EngineName, Mode=OneWay}"
                                             FontSize="15" FontWeight="Bold" Foreground="#FFCDD6F4"/>
                                    </TextBlock>
                                    <TextBlock DockPanel.Dock="Right" Text="{Binding StatusText}"
                                               FontSize="11" Foreground="#FFA6ADC8"
                                               VerticalAlignment="Center" HorizontalAlignment="Right"
                                               Margin="8,0,0,0"/>
                                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="Version:" Foreground="#FF6C7086" FontSize="11"
                                                   VerticalAlignment="Center" Margin="0,0,5,0"/>
                                        <ComboBox ItemsSource="{Binding AvailableVersions}"
                                                  SelectedItem="{Binding SelectedVersion}"
                                                  IsEnabled="{Binding CanChangeVersion}"
                                                  DisplayMemberPath="DisplayName"
                                                  MinWidth="150" Height="24"
                                                  FontSize="11"
                                                  Background="#FF45475A" Foreground="#FFCDD6F4"
                                                  BorderBrush="#FF585B70" BorderThickness="1"/>
                                        <TextBlock Text="(fixiert)"
                                                   Foreground="#FF585B70" FontSize="10" FontStyle="Italic"
                                                   VerticalAlignment="Center" Margin="6,0,0,0"
                                                   Visibility="{Binding IsInstalled, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                    </StackPanel>
                                </DockPanel>

                                <!-- Row 1: Port + Path + optional progress -->
                                <DockPanel Grid.Row="1" Margin="18,0,0,4">
                                    <WrapPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                                        <TextBlock Foreground="#FF6C7086" FontSize="11" Margin="0,0,14,0">
                                            <Run Text="Port: "/>
                                            <Run Text="{Binding Port, Mode=OneWay}" Foreground="#FFCDD6F4"/>
                                        </TextBlock>
                                        <TextBlock Foreground="#FF6C7086" FontSize="11">
                                            <Run Text="Pfad: "/>
                                            <Run Text="{Binding InstallPath, Mode=OneWay}" Foreground="#FF89B4FA"/>
                                        </TextBlock>
                                    </WrapPanel>
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                                VerticalAlignment="Center" HorizontalAlignment="Right"
                                                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"
                                                Margin="12,0,0,0">
                                        <ProgressBar Value="{Binding DownloadProgress}" Height="5" Width="120"
                                                     Minimum="0" Maximum="100"
                                                     Foreground="#FF89B4FA" Background="#FF45475A"
                                                     BorderThickness="0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding StatusMessage}"
                                                   Foreground="#FFA6ADC8" FontSize="10" Margin="6,0,0,0"
                                                   VerticalAlignment="Center" MaxWidth="180"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </DockPanel>

                                <!-- Row 2: Action buttons -->
                                <WrapPanel Grid.Row="2" Margin="16,2,0,2">
                                    <Button Content="📥 Installieren"
                                            Style="{StaticResource InstallButton}"
                                            Command="{Binding InstallCommand}"/>
                                    <Button Content="▶ Starten"
                                            Style="{StaticResource StartButton}"
                                            Command="{Binding StartCommand}"/>
                                    <Button Content="⏹ Stoppen"
                                            Style="{StaticResource StopButton}"
                                            Command="{Binding StopCommand}"/>
                                    <Button Content="🗑 Deinstallieren"
                                            Style="{StaticResource UninstallButton}"
                                            Command="{Binding UninstallCommand}"/>
                                </WrapPanel>

                                <!-- Row 3: Collapsible log -->
                                <Expander Grid.Row="3" Header="Log"
                                          Foreground="#FF6C7086" FontSize="11"
                                          Margin="16,2,0,0"
                                          IsExpanded="False">
                                    <TextBox Text="{Binding LogOutput, Mode=OneWay}"
                                             IsReadOnly="True" TextWrapping="Wrap"
                                             MaxHeight="100" VerticalScrollBarVisibility="Auto"
                                             Background="#FF181825" Foreground="#FFA6ADC8"
                                             BorderThickness="0" FontFamily="Consolas"
                                             FontSize="10" Padding="6" Margin="0,2,0,0"/>
                                </Expander>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>
